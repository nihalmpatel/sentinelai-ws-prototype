# Local development defaults for Sentinel backend
# Do not commit real secrets here.

PORT=3000

# ── LLM Provider Configuration ──
# Options: stub (default, no API key needed), openai, anthropic
LLM_PROVIDER=stub

# Required when LLM_PROVIDER is openai or anthropic:
# LLM_API_KEY=sk-your-key-here

# Override the default model for the chosen provider:
# LLM_MODEL=gpt-4o              # openai default
# LLM_MODEL=claude-sonnet-4-20250514  # anthropic default

# Override the API base URL (useful for proxies or local LLM servers):
# LLM_BASE_URL=https://api.openai.com/v1

# Request timeout in milliseconds (default: 30000)
# LLM_TIMEOUT_MS=30000

# Max retries on transient failures (default: 2)
# LLM_MAX_RETRIES=2
